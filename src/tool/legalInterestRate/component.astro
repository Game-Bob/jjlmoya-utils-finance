---
import { Icon } from 'astro-icon/components';
import type { KnownLocale } from '../../types';

interface Props {
  locale?: KnownLocale;
  ui?: Record<string, unknown>;
}

const { ui } = Astro.props;
---

<div class="lir-wrapper" data-currency-symbol={ui.currencySymbol} data-currency-code={ui.currencyCode} data-currency-locale={ui.currencyLocale}>
  <div class="lir-container">
    <header class="lir-header">
      <span class="lir-badge">{ui.labelBadge}</span>
      <h2 class="lir-title">{ui.labelTitle}</h2>
      <p class="lir-subtitle">{ui.labelSubtitle}</p>
    </header>

    <div class="lir-main-rates">
      <article class="rate-card">
        <span class="rate-label">{ui.labelLegalInterest}</span>
        <span class="rate-value">3,25%</span>
        <span class="rate-subtext">{ui.labelActive}</span>
      </article>

      <article class="rate-card">
        <span class="rate-label">{ui.labelDelayInterest}</span>
        <span class="rate-value">4,06%</span>
        <span class="rate-subtext">{ui.labelTributary}</span>
      </article>

      <article class="rate-card">
        <span class="rate-label">{ui.labelCommercialOperations}</span>
        <span class="rate-value">10,15%</span>
        <span class="rate-subtext">{ui.labelFirstHalf}</span>
      </article>
    </div>

    <section class="lir-calculator-section">
      <h2 class="calculator-title">
        <Icon name="mdi:calculator-variant" />
        {ui.labelQuickCalculator}
      </h2>

      <div class="calculator-grid">
        <div class="input-group">
          <label for="capital">{ui.labelCapital}</label>
          <div class="input-container">
            <input
              type="number"
              id="capital"
              placeholder="0.00"
              class="lir-input"
              value="1000"
            />
            <span class="currency-suffix">{ui.currencySymbol}</span>
          </div>
        </div>

        <div class="input-group">
          <label for="days">{ui.labelDays}</label>
          <div class="input-container">
            <input
              type="number"
              id="days"
              placeholder="365"
              class="lir-input"
              value="365"
            />
            <span class="currency-suffix">días</span>
          </div>
        </div>

        <div class="lir-results-card">
          <div class="result-item">
            <span class="result-label">{ui.labelInterestGenerated}</span>
            <span class="result-amount" id="result-interest">32,50 {ui.currencySymbol}</span>
          </div>
          <div class="result-item result-total">
            <span class="total-label">{ui.labelTotalToPay}</span>
            <span class="total-amount" id="result-total">1.032,50 {ui.currencySymbol}</span>
          </div>
        </div>
      </div>

      <div class="lir-info-msg">
        <div class="info-icon">
          <Icon name="mdi:information-outline" />
        </div>
        <div class="info-content">
          <p>{ui.labelFormula}</p>
          <code class="info-formula">Interés = (Capital × 3,25% × Días) / (365 × 100)</code>
          <p>{ui.labelBase}</p>
        </div>
      </div>
    </section>
  </div>
</div>

<style>
:root {
  --lir-primary: #856404;
  --lir-secondary: #b8860b;
  --lir-accent: #6c757d;
  --lir-bg-glass: rgba(255, 255, 255, 0.9);
  --lir-border-glass: rgba(184, 134, 11, 0.3);
  --lir-text-main: #212529;
  --lir-text-muted: #495057;
  --lir-glow: rgba(184, 134, 11, 0.1);
}

:global(.theme-dark) {
  --lir-bg-glass: rgba(15, 23, 42, 0.9);
  --lir-border-glass: rgba(184, 134, 11, 0.3);
  --lir-text-main: #f8fafc;
  --lir-text-muted: #94a3b8;
  --lir-glow: rgba(184, 134, 11, 0.15);
}

:global([data-theme='dark']) {
  --lir-bg-glass: rgba(15, 23, 42, 0.9);
  --lir-border-glass: rgba(184, 134, 11, 0.3);
  --lir-text-main: #f8fafc;
  --lir-text-muted: #94a3b8;
  --lir-glow: rgba(184, 134, 11, 0.15);
}

.lir-wrapper {
  max-width: 900px;
  margin: 2rem auto;
  padding: 1rem;
}

.lir-container {
  background: var(--lir-bg-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 2px solid var(--lir-border-glass);
  border-radius: 2rem;
  padding: 2.5rem;
  position: relative;
  overflow: hidden;
  box-shadow: 0 15px 35px -5px rgba(184, 134, 11, 0.1);
}

.lir-header {
  text-align: center;
  margin-bottom: 2.5rem;
}

.lir-badge {
  display: inline-block;
  padding: 0.25rem 1rem;
  background: rgba(184, 134, 11, 0.1);
  border: 1px solid var(--lir-primary);
  color: var(--lir-primary);
  border-radius: 2rem;
  font-size: 0.75rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  margin-bottom: 1rem;
}

.lir-title {
  font-size: 2.25rem;
  font-weight: 900;
  color: var(--lir-text-main);
  margin-bottom: 0.5rem;
  line-height: 1.1;
}

.lir-subtitle {
  color: var(--lir-text-muted);
  font-size: 1.1rem;
  max-width: 600px;
  margin: 0 auto;
}

.lir-main-rates {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 1.25rem;
  margin-bottom: 2.5rem;
}

.rate-card {
  background: white;
  border: 1px solid rgba(184, 134, 11, 0.15);
  border-radius: 1.5rem;
  padding: 1.5rem;
  text-align: center;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: center;
  box-shadow: 0 5px 15px rgba(0, 0, 0, 0.02);
}

:global(.theme-dark) .rate-card,
:global([data-theme='dark']) .rate-card {
  background: rgba(255, 255, 255, 0.03);
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
}

.rate-card:hover {
  transform: translateY(-5px);
  border-color: var(--lir-primary);
}

.rate-label {
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--lir-text-muted);
  margin-bottom: 0.5rem;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.rate-value {
  font-size: 3rem;
  font-weight: 950;
  color: var(--lir-secondary);
  line-height: 1;
  margin-bottom: 0.25rem;
}

.rate-subtext {
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--lir-text-main);
}

.lir-calculator-section {
  background: #f8f9fa;
  border: 1px solid rgba(0, 0, 0, 0.03);
  border-radius: 1.75rem;
  padding: 2rem;
}

:global(.theme-dark) .lir-calculator-section,
:global([data-theme='dark']) .lir-calculator-section {
  background: rgba(255, 255, 255, 0.02);
}

.calculator-title {
  font-size: 1.4rem;
  font-weight: 800;
  color: var(--lir-text-main);
  margin-bottom: 1.5rem;
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.calculator-title :global(svg) {
  color: var(--lir-primary);
}

.calculator-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
}

.input-group {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.input-group label {
  font-weight: 700;
  color: var(--lir-text-muted);
  font-size: 0.85rem;
}

.input-container {
  position: relative;
}

.lir-input {
  width: 100%;
  background: white;
  border: 2px solid #e9ecef;
  padding: 0.85rem 1.25rem;
  border-radius: 1rem;
  color: #212529;
  font-size: 1.1rem;
  font-weight: 700;
  transition: all 0.3s;
}

:global(.theme-dark) .lir-input,
:global([data-theme='dark']) .lir-input {
  background: rgba(15, 23, 42, 0.6);
  border-color: rgba(255, 255, 255, 0.1);
  color: white;
}

.lir-input:focus {
  outline: none;
  border-color: var(--lir-primary);
  box-shadow: 0 0 10px var(--lir-glow);
}

.currency-suffix {
  position: absolute;
  right: 1.25rem;
  top: 50%;
  transform: translateY(-50%);
  color: var(--lir-text-muted);
  font-weight: 800;
  font-size: 0.9rem;
}

.lir-results-card {
  grid-column: span 2;
  background: linear-gradient(135deg, rgba(184, 134, 11, 0.03) 0%, #fff 100%);
  border: 1px solid var(--lir-border-glass);
  border-radius: 1.5rem;
  padding: 1.5rem 2rem;
  margin-top: 0.5rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

:global(.theme-dark) .lir-results-card,
:global([data-theme='dark']) .lir-results-card {
  background: linear-gradient(135deg, rgba(184, 134, 11, 0.1) 0%, rgba(15, 23, 42, 0.6) 100%);
}

.result-item {
  display: flex;
  flex-direction: column;
}

.result-label {
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--lir-text-muted);
}

.result-amount {
  font-size: 2.25rem;
  font-weight: 950;
  color: var(--lir-secondary);
}

.result-total {
  text-align: right;
}

.total-label {
  font-size: 0.95rem;
  font-weight: 800;
  color: var(--lir-text-main);
}

.total-amount {
  font-size: 2.5rem;
  font-weight: 950;
  color: var(--lir-primary);
}

.lir-info-msg {
  margin-top: 1.5rem;
  padding: 1.25rem;
  background: rgba(184, 134, 11, 0.05);
  border: 1px solid rgba(184, 134, 11, 0.1);
  border-radius: 1.25rem;
  display: flex;
  gap: 1.25rem;
  align-items: flex-start;
}

:global(.theme-dark) .lir-info-msg,
:global([data-theme='dark']) .lir-info-msg {
  background: rgba(184, 134, 11, 0.08);
}

.info-icon {
  background: var(--lir-primary);
  color: white;
  width: 32px;
  height: 32px;
  min-width: 32px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.2rem;
  box-shadow: 0 4px 10px rgba(184, 134, 11, 0.2);
}

.info-content {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  min-width: 0;
}

.info-content p {
  margin: 0;
  font-size: 0.85rem;
  color: var(--lir-text-muted);
  line-height: 1.5;
}

.info-formula {
  background: white;
  padding: 0.5rem 1rem;
  border-radius: 0.75rem;
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--lir-primary);
  border: 1px solid rgba(184, 134, 11, 0.1);
  display: inline-block;
  align-self: flex-start;
  margin: 0.25rem 0;
}

:global(.theme-dark) .info-formula,
:global([data-theme='dark']) .info-formula {
  background: rgba(0, 0, 0, 0.2);
  color: var(--lir-secondary);
}

@media (max-width: 768px) {
  .lir-wrapper {
    padding: 1rem;
    margin: 0.5rem auto;
    box-sizing: border-box;
  }

  .lir-container {
    padding: 1.25rem;
    border-radius: 1.25rem;
    width: 100%;
    box-sizing: border-box;
  }

  .lir-badge {
    padding: 0.2rem 0.75rem;
    font-size: 0.65rem;
    margin-bottom: 0.5rem;
  }

  .lir-title {
    font-size: 1.5rem;
    padding: 0;
  }

  .lir-subtitle {
    font-size: 0.9rem;
    padding: 0;
  }

  .lir-main-rates {
    grid-template-columns: 1fr;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .rate-card {
    padding: 1rem;
    border-radius: 1rem;
  }

  .rate-label {
    font-size: 0.75rem;
  }

  .rate-value {
    font-size: 2.25rem;
  }

  .rate-subtext {
    font-size: 0.85rem;
  }

  .lir-calculator-section {
    padding: 1rem;
    border-radius: 1rem;
  }

  .calculator-title {
    font-size: 1.2rem;
    margin-bottom: 1rem;
  }

  .calculator-grid {
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  .lir-input {
    padding: 0.75rem 2.5rem 0.75rem 1rem;
    font-size: 1rem;
    box-sizing: border-box;
  }

  .lir-results-card {
    grid-column: span 1;
    flex-direction: column;
    padding: 1rem;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .result-item.result-total {
    padding-top: 0.75rem;
  }

  .result-label,
  .total-label {
    font-size: 0.85rem;
  }

  .result-amount {
    font-size: 1.75rem;
  }

  .total-amount {
    font-size: 2rem;
  }

  .lir-info-msg {
    padding: 0.75rem;
    gap: 0.75rem;
    width: 100%;
    box-sizing: border-box;
    overflow: hidden;
  }

  .info-icon {
    width: 24px;
    height: 24px;
    min-width: 24px;
    font-size: 0.9rem;
  }

  .info-formula {
    width: 100%;
    box-sizing: border-box;
    padding: 0.5rem 0.75rem;
    font-size: 0.7rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    display: block;
    border-radius: 0.5rem;
    overflow-wrap: break-word;
    white-space: normal;
  }
}

@media (max-width: 480px) {
  .lir-wrapper {
    padding: 0.75rem;
  }

  .lir-container {
    padding: 1rem;
  }

  .lir-title {
    font-size: 1.3rem;
  }

  .lir-subtitle {
    font-size: 0.85rem;
  }

  .rate-value {
    font-size: 1.75rem;
  }

  .lir-calculator-section {
    padding: 0.75rem;
  }

  .calculator-title {
    font-size: 1rem;
  }

  .result-amount {
    font-size: 1.4rem;
  }

  .total-amount {
    font-size: 1.5rem;
  }

  .lir-input {
    font-size: 0.9rem;
  }

  .info-content p {
    font-size: 0.75rem;
  }

  .info-formula {
    font-size: 0.65rem;
  }
}
</style>

<script>
  import { LegalInterestLogic } from './logic';

  const capitalInput = document.getElementById('capital') as HTMLInputElement | null;
  const daysInput = document.getElementById('days') as HTMLInputElement | null;
  const interestDisplay = document.getElementById('result-interest');
  const totalDisplay = document.getElementById('result-total');

  const container = document.querySelector('.lir-wrapper') as HTMLElement;
  const currencyLocale = container?.getAttribute('data-currency-locale') || 'es-ES';
  const currencySymbol = container?.getAttribute('data-currency-symbol') || '€';

  function formatCurrency(val: number): string {
    return new Intl.NumberFormat(currencyLocale, {
      minimumFractionDigits: 2,
      maximumFractionDigits: 2,
    }).format(val);
  }

  function calculate() {
    if (!capitalInput || !daysInput) return;
    const capital = parseFloat(capitalInput.value) || 0;
    const days = parseFloat(daysInput.value) || 0;

    const result = LegalInterestLogic.calculateInterest(capital, days);

    if (interestDisplay) {
      interestDisplay.textContent = `${formatCurrency(result.interest)} ${currencySymbol}`;
    }
    if (totalDisplay) {
      totalDisplay.textContent = `${formatCurrency(result.total)} ${currencySymbol}`;
    }
  }

  capitalInput?.addEventListener('input', calculate);
  daysInput?.addEventListener('input', calculate);

  calculate();
</script>
