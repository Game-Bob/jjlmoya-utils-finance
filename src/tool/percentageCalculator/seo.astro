---
import type { ToolLocaleContent } from '../../types';
import type { PercentageCalculatorUI } from './ui';

interface Props {
  content: ToolLocaleContent<PercentageCalculatorUI>;
}

const { content } = Astro.props;
---

<div class="pc-seo">
  {
    content.seo?.map((section) => {
      if (section.type === 'title') {
        const HeadingLevel = `h${section.level || 2}` as any;
        return <HeadingLevel class="pc-seo-title">{section.text}</HeadingLevel>;
      }

      if (section.type === 'paragraph') {
        return <p class="pc-seo-paragraph" set:html={section.html} />;
      }

      if (section.type === 'tip') {
        return (
          <div class="pc-seo-tip">
            <strong>{section.title}</strong>
            <div set:html={section.html} />
          </div>
        );
      }

      if (section.type === 'comparative') {
        return (
          <div class="pc-seo-comparative" style={{ gridTemplateColumns: `repeat(${section.columns || 2}, 1fr)` }}>
            {section.items?.map((item) => (
              <div class="pc-seo-comparative-item" class:list={{ highlight: item.highlight }}>
                <h4>{item.title}</h4>
                <p>{item.description}</p>
                <ul>
                  {item.points?.map((point) => (
                    <li>{point}</li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        );
      }

      return null;
    })
  }
</div>

<style>
.pc-seo {
  max-width: 1200px;
  margin: 3rem auto;
  padding: 0 2rem;
}

.pc-seo-title {
  font-size: 1.5rem;
  font-weight: 600;
  color: var(--pc-primary-light);
  margin: 2rem 0 1rem;
}

.pc-seo-paragraph {
  font-size: 1rem;
  line-height: 1.6;
  color: var(--pc-text-light);
  margin-bottom: 1.5rem;
}

.pc-seo-tip {
  background: var(--pc-accent-light);
  border-left: 4px solid var(--pc-primary-light);
  padding: 1.5rem;
  border-radius: 8px;
  margin-bottom: 1.5rem;
  color: var(--pc-text-light);
}

.pc-seo-tip strong {
  display: block;
  margin-bottom: 0.75rem;
  color: var(--pc-primary-light);
}

.pc-seo-comparative {
  display: grid;
  gap: 1.5rem;
  margin-bottom: 2rem;
}

.pc-seo-comparative-item {
  border: 1px solid var(--pc-border-light);
  border-radius: 8px;
  padding: 1.5rem;
  background: white;
}

.pc-seo-comparative-item.highlight {
  background: var(--pc-accent-light);
  border-color: var(--pc-primary-light);
  border-width: 2px;
}

.pc-seo-comparative-item h4 {
  font-size: 1.1rem;
  color: var(--pc-primary-light);
  margin-bottom: 0.5rem;
}

.pc-seo-comparative-item p {
  font-size: 0.95rem;
  color: var(--pc-text-light);
  margin-bottom: 1rem;
}

.pc-seo-comparative-item ul {
  list-style: none;
  padding: 0;
}

.pc-seo-comparative-item li {
  font-size: 0.9rem;
  color: var(--pc-text-light);
  padding: 0.35rem 0;
  padding-left: 1.5rem;
  position: relative;
}

.pc-seo-comparative-item li:before {
  content: '•';
  position: absolute;
  left: 0;
  color: var(--pc-primary-light);
  font-weight: bold;
}
</style>
