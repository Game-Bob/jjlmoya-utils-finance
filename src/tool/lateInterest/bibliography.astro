---
import type { ToolLocaleContent } from '../../types';
import type { LateInterestUI } from './ui';

interface Props {
  content: ToolLocaleContent<LateInterestUI>;
}

const { content } = Astro.props;
---

<div class="li-bibliography">
  <h3 class="li-bibliography-title">{content.bibliographyTitle}</h3>
  <ul class="li-bibliography-list">
    {
      content.bibliography?.map((item) => (
        <li class="li-bibliography-item">
          <a href={item.url} target="_blank" rel="noopener noreferrer" class="li-bibliography-link">
            {item.name}
          </a>
        </li>
      ))
    }
  </ul>
</div>

<style>
.li-bibliography {
  max-width: 1200px;
  margin: 3rem auto;
  padding: 0 2rem;
}

.li-bibliography-title {
  font-size: 1.3rem;
  font-weight: 600;
  color: var(--li-accent);
  margin-bottom: 1.5rem;
}

.li-bibliography-list {
  list-style: none;
  padding: 0;
}

.li-bibliography-item {
  padding: 0.75rem 0;
  border-bottom: 1px solid var(--li-border);
}

.li-bibliography-item:last-child {
  border-bottom: none;
}

.li-bibliography-link {
  color: var(--li-accent);
  text-decoration: none;
  font-size: 0.95rem;
  transition: color 0.2s;
}

.li-bibliography-link:hover {
  color: var(--li-primary);
  text-decoration: underline;
}
</style>
