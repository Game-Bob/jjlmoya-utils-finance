---
import type { BibliographyEntry } from '../../types';

interface Props {
  items: BibliographyEntry[];
}

const { items } = Astro.props;
---

<div class="ibs-bibliography">
  <ul>
    {items.map((item) => (
      <li>
        <a href={item.url} target="_blank" rel="noopener noreferrer">
          {item.name}
        </a>
      </li>
    ))}
  </ul>
</div>

<style>
.ibs-bibliography {
  margin-top: 2rem;
}

.ibs-bibliography ul {
  list-style-type: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.ibs-bibliography li {
  padding: 1rem;
  border-left: 4px solid #6366f1;
  background: rgba(99, 102, 241, 0.05);
  border-radius: 8px;
}

.ibs-bibliography a {
  color: #6366f1;
  text-decoration: none;
  font-weight: 600;
  transition: color 0.2s;
}

.ibs-bibliography a:hover {
  color: #4f46e5;
  text-decoration: underline;
}

:global(.theme-dark) .ibs-bibliography li,
:global([data-theme='dark']) .ibs-bibliography li {
  background: rgba(99, 102, 241, 0.1);
  border-left-color: #60a5fa;
}

:global(.theme-dark) .ibs-bibliography a,
:global([data-theme='dark']) .ibs-bibliography a {
  color: #60a5fa;
}

:global(.theme-dark) .ibs-bibliography a:hover,
:global([data-theme='dark']) .ibs-bibliography a:hover {
  color: #93c5fd;
}
</style>
