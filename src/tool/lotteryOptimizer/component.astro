}

.lo-badge-icon :global(svg) {
    width: 1.5rem;
    height: 1.5rem;
}

.lo-panel-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
}

.lo-input-section {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
}

.lo-slider-group {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.lo-slider-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.lo-slider-header label {
    font-weight: 700;
    color: var(--lo-text-title);
}

.lo-slider-value {
    font-weight: 700;
    color: var(--lo-focus-border);
}

.lo-slider {
    width: 100%;
    height: 0.5rem;
    border-radius: 0.25rem;
    background: var(--lo-bar-bg);
    outline: none;
    -webkit-appearance: none;
    appearance: none;
