</style>

<script>
    import { LOTTERY_DATA, LotteryLogic, type LotteryId } from './logic';

    const btns = document.querySelectorAll('[data-game-btn]');
    const panel = document.getElementById('calculator-panel');
    const slider = document.getElementById('ticket-slider') as HTMLInputElement;
    const ticketCountDisplay = document.getElementById('ticket-count-display');
    const totalCostDisplay = document.getElementById('display-total-cost');
    const probDisplay = document.getElementById('stat-probability');
    const probBar = document.getElementById('prob-bar');
    const evDisplay = document.getElementById('stat-ev');
    const efficiencyDisplay = document.getElementById('stat-efficiency');
    const efficiencyLabel = document.getElementById('efficiency-label');
    const recommendationText = document.getElementById('recommendation-text');
    const optimalCount = document.getElementById('optimal-count');
    const comparisonTbody = document.getElementById('comparison-tbody');
    const segments = document.querySelectorAll('.lo-efficiency-segment');
    const container = document.querySelector('.lo-container') as HTMLElement;

    const currencySymbol = container?.getAttribute('data-currency-symbol') || '€';
    const currencyCode = container?.getAttribute('data-currency-code') || 'EUR';
    const currencyLocale = container?.getAttribute('data-currency-locale') || 'es-ES';
    const labelLow = container?.getAttribute('data-label-low') || 'Baja';
    const labelMedium = container?.getAttribute('data-label-medium') || 'Media';
    const labelHigh = container?.getAttribute('data-label-high') || 'Alta';
    const labelAccessible = container?.getAttribute('data-label-accessible') || 'Accesible';
    const labelDifficult = container?.getAttribute('data-label-difficult') || 'Difícil';
    const labelExtreme = container?.getAttribute('data-label-extreme') || 'Extrema';

    let gameTranslations: Record<string, { name: string; description: string }> = {};
    try {
        const translationsJson = container?.getAttribute('data-game-translations');
        if (translationsJson) gameTranslations = JSON.parse(translationsJson);
    } catch {
        void 0;
    }

    function formatCurrency(val: number): string {
        return new Intl.NumberFormat(currencyLocale, {
            style: 'currency',
            currency: currencyCode,
        }).format(val);
    }

    function getDifficulty(odds: number): string {
        if (odds < 200000) return labelAccessible;
        if (odds < 20000000) return labelDifficult;
        return labelExtreme;
    }

    function formatPrize(jackpot: number): string {
        if (jackpot > 1000000) {
            return `${(jackpot / 1000000).toFixed(1)}M${currencySymbol}`;
        }
        return `${(jackpot / 1000).toFixed(0)}k${currencySymbol}`;
    }

    function getGameColor(gameId: LotteryId): string {
        return gameId === 'gordo' || gameId === 'nino' ? '#fbbf24' : '#10b981';
    }

    function initializeGames() {
        Object.entries(LOTTERY_DATA).forEach(([id, game]) => {
            const btn = document.querySelector(`[data-game-btn][data-id="${id}"]`) as HTMLElement;
            if (btn) {
                const name = btn.querySelector('.lo-game-name') as HTMLElement;
                const desc = btn.querySelector('.lo-game-description') as HTMLElement;
                const odds = btn.querySelector('.lo-game-odds') as HTMLElement;
                const translation = gameTranslations[id] || { name: game.name, description: game.description };
                if (name) name.textContent = translation.name;
                if (desc) desc.textContent = translation.description;
                if (odds) odds.textContent = `1/${game.odds.toLocaleString()}`;
            }
        });

        Object.values(LOTTERY_DATA).forEach((game) => {
            const row = document.createElement('tr');
            const difficulty = getDifficulty(game.odds);
            const prize = formatPrize(game.jackpot);
            const color = getGameColor(game.id as LotteryId);
            row.innerHTML = `
                <td><span style="display:inline-block;width:0.5rem;height:0.5rem;border-radius:50%;background:${color};margin-right:0.75rem"></span>${game.name}</td>
                <td class="lo-table-right">${game.cost}${currencySymbol}</td>
                <td class="lo-table-right">${prize}</td>
                <td class="lo-table-right">${difficulty}</td>
            `;
            comparisonTbody?.appendChild(row);
        });
    }

    function getEfficiencyLabel(eff: number): string {
        if (eff > 65) return labelHigh;
        if (eff > 50) return labelMedium;
        return labelLow;
    }

    function updateEfficiencySegments(eff: number) {
        segments.forEach((seg, i) => {
            if (eff >= (i + 1) * 10) {
                seg.classList.add('lo-active');
            } else {
                seg.classList.remove('lo-active');
            }
        });
    }

    function updateExpectedValue(expectedValue: number) {
        if (!evDisplay) return;
        evDisplay.textContent = formatCurrency(expectedValue);
        const className = expectedValue < 0 ? 'lo-negative' : 'lo-positive';
        evDisplay.className = `lo-stat-value ${className}`;
    }

    function updateProbability(winProbability: number) {
        if (probDisplay) probDisplay.textContent = `${winProbability.toFixed(5)}%`;
        if (probBar) probBar.style.width = `${Math.min(winProbability * 10, 100)}%`;
    }

    function updateStats(tickets: number, stats: ReturnType<typeof LotteryLogic.calculateStats>) {
        if (ticketCountDisplay) ticketCountDisplay.textContent = tickets.toString();
        if (totalCostDisplay) totalCostDisplay.textContent = formatCurrency(stats.totalCost);
        updateProbability(stats.winProbability);
        updateExpectedValue(stats.expectedValue);
        if (recommendationText) recommendationText.textContent = stats.recommendation;
        if (optimalCount) optimalCount.textContent = stats.optimalTickets.toString();
    }

    function updateEfficiency(selectedId: LotteryId) {
        const eff = Math.min(LOTTERY_DATA[selectedId].payoutRate, 100);
        if (efficiencyDisplay) efficiencyDisplay.textContent = eff.toFixed(1);
        if (efficiencyLabel) efficiencyLabel.textContent = getEfficiencyLabel(eff);
        updateEfficiencySegments(eff);
    }

    function update() {
        const selectedBtn = document.querySelector('.lo-selected') as HTMLElement;
        if (!selectedBtn) return;

        const selectedId = selectedBtn.getAttribute('data-id') as LotteryId;
        const tickets = parseInt(slider.value);
        const stats = LotteryLogic.calculateStats(selectedId, tickets);

        updateStats(tickets, stats);
        updateEfficiency(selectedId);
    }

    btns.forEach((btn) => {
        btn.addEventListener('click', () => {
            btns.forEach((b) => b.classList.remove('lo-selected'));
            btn.classList.add('lo-selected');
            if (panel) panel.classList.remove('lo-hidden');
            update();
        });
    });

    slider?.addEventListener('input', update);
    initializeGames();
</script>

<style is:global>
.lo-game-btn.lo-selected {
    border-color: var(--lo-focus-border);
    background: rgba(16, 185, 129, 0.05);
    box-shadow: 0 0 0 4px var(--lo-focus-ring);
}

.lo-stat-value.lo-negative {
    color: #ef4444;
}

.lo-stat-value.lo-positive {
    color: #10b981;
}

.lo-efficiency-segment.lo-active {
    background: var(--lo-bar-fill);
}
</style>
