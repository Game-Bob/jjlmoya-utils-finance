---
import { Icon } from 'astro-icon/components';
import type { KnownLocale } from '../../types';

interface Props {
  locale?: KnownLocale;
  ui?: Record<string, unknown>;
}

const { ui } = Astro.props;
---

<div class="lo-container" data-currency-symbol={ui.currencySymbol} data-currency-code={ui.currencyCode} data-currency-locale={ui.currencyLocale} data-label-units={ui.labelUnits} data-label-low={ui.labelLow} data-label-medium={ui.labelMedium} data-label-high={ui.labelHigh} data-label-accessible={ui.labelAccessible} data-label-difficult={ui.labelDifficult} data-label-extreme={ui.labelExtreme} data-label-optimal={ui.labelOptimalCutoff} data-game-translations={JSON.stringify(ui.gameTranslations)}>
    <div class="lo-games-grid">
        {['gordo', 'nino', 'euromillones', 'primitiva', 'bonoloto'].map((gameId) => (
            <button class="lo-game-btn" data-game-btn data-id={gameId}>
                <div class="lo-game-icon">
                    {gameId === 'gordo' || gameId === 'nino' ? (
                        <Icon name="mdi:gift" />
                    ) : (
                        <Icon name="mdi:dice-multiple" />
                    )}
                </div>
                <h4 class="lo-game-name">-</h4>
                <p class="lo-game-description">-</p>
                <div class="lo-game-footer">
                    <span class="lo-game-odds">-</span>
                    <Icon name="mdi:arrow-right" class="lo-arrow-icon" />
                </div>
            </button>
        ))}
    </div>

    <div id="calculator-panel" class="lo-panel lo-hidden">
        <div class="lo-panel-card">
            <div class="lo-panel-header">
                <div>
                    <h3 class="lo-panel-title">{ui.labelConfigurePlay}</h3>
                    <p class="lo-panel-subtitle">{ui.labelAdjustQuantity}</p>
                </div>
                <div class="lo-investment-badge">
                    <div>
                        <p class="lo-badge-label">{ui.labelTotalInvestment}</p>
                        <p class="lo-badge-value" id="display-total-cost">0,00€</p>
                    </div>
                    <div class="lo-badge-icon">
                        <Icon name="mdi:credit-card" />
                    </div>
                </div>
            </div>

            <div class="lo-panel-content">
                <div class="lo-input-section">
                    <div class="lo-slider-group">
                        <div class="lo-slider-header">
                            <label>{ui.labelTickets}</label>
                            <span class="lo-slider-value" id="ticket-count-display">1</span>
                        </div>
                        <input type="range" id="ticket-slider" min="1" max="100" value="1" class="lo-slider" />
                        <div class="lo-slider-labels">
                            <span>1 {ui.labelUnits}</span>
                            <span>100 {ui.labelUnits}</span>
                        </div>
                    </div>

                    <div class="lo-recommendation-box">
                        <div class="lo-recommendation-header">
                            <Icon name="mdi:alert-circle" class="lo-alert-icon" />
                            <h4>{ui.labelExposureAnalysis}</h4>
                        </div>
                        <p class="lo-recommendation-text" id="recommendation-text">{ui.labelSelectLottery}</p>
                        <div id="optimal-tag" class="lo-optimal-tag lo-hidden">
                            <span>{ui.labelOptimalCutoff}: <span id="optimal-count">0</span> {ui.labelUnits}</span>
                        </div>
                    </div>
                </div>

                <div class="lo-stats-grid">
                    <div class="lo-stat-card">
                        <p class="lo-stat-label">{ui.labelProbabilitySuccess}</p>
                        <p class="lo-stat-value" id="stat-probability">0.00%</p>
                        <div class="lo-stat-bar">
                            <div class="lo-stat-bar-fill" id="prob-bar"></div>
                        </div>
                    </div>

                    <div class="lo-stat-card">
                        <p class="lo-stat-label">{ui.labelExpectedValue}</p>
                        <p class="lo-stat-value" id="stat-ev">-0.00€</p>
                        <p class="lo-stat-hint">{ui.labelReturnTheoretical}</p>
                    </div>

                    <div class="lo-stat-card lo-stat-card-full">
                        <div class="lo-stat-header">
                            <p class="lo-stat-label">{ui.labelSocialReturnIndex}</p>
                            <span class="lo-efficiency-label" id="efficiency-label">{ui.labelLow}</span>
                        </div>
                        <div class="lo-efficiency-value">
                            <p class="lo-stat-value" id="stat-efficiency">0.0</p>
                            <p class="lo-efficiency-max">/ 100</p>
                        </div>
                        <div class="lo-efficiency-segments" id="efficiency-segments">
                            {[...Array(10)].map((_, i) => (
                                <div class="lo-efficiency-segment" data-index={i}></div>
                            ))}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="lo-comparison-section">
        <div class="lo-comparison-header">
            <div class="lo-comparison-icon">
                <Icon name="mdi:chart-bar" />
            </div>
            <div>
                <h3>{ui.labelComparison}</h3>
                <p>{ui.labelCost} vs {ui.labelTypicalPrize}</p>
            </div>
        </div>

        <div class="lo-table-wrapper">
            <table class="lo-table">
                <thead>
                    <tr>
                        <th>{ui.labelLottery}</th>
                        <th class="lo-table-right">{ui.labelCost}</th>
                        <th class="lo-table-right">{ui.labelTypicalPrize}</th>
                        <th class="lo-table-right">{ui.labelDifficulty}</th>
                    </tr>
                </thead>
                <tbody id="comparison-tbody">
                </tbody>
            </table>
        </div>

        <p class="lo-table-note">{ui.labelNote}</p>
    </div>
</div>

<style>
:root {
    --lo-bg-card: #fff;
    --lo-border-card: #eef2f6;
    --lo-shadow-card: 0 4px 6px -1px rgba(0, 0, 0, 0.02), 0 20px 40px -8px rgba(0, 0, 0, 0.05);
    --lo-text-title: #0f172a;
    --lo-text-secondary: #64748b;
    --lo-text-primary: #1e293b;
    --lo-bg-input: #f8fafc;
    --lo-border-input: #f1f5f9;
    --lo-focus-border: #10b981;
    --lo-focus-ring: rgba(16, 185, 129, 0.15);
    --lo-icon-color: #10b981;
    --lo-bg-button: #0f172a;
    --lo-text-button: #fff;
    --lo-bg-hover: #1e293b;
    --lo-bg-stat: #fff;
    --lo-border-stat: #eef2f6;
    --lo-bar-bg: #f1f5f9;
    --lo-bar-fill: #10b981;
    --lo-recommendation-bg: #eef5ff;
    --lo-recommendation-border: #d0e4ff;
    --lo-recommendation-icon: #3b82f6;
}

:global(.theme-dark) {
    --lo-bg-card: #0f172a;
    --lo-border-card: rgba(255, 255, 255, 0.05);
    --lo-text-title: #f8fafc;
    --lo-text-secondary: #94a3b8;
    --lo-text-primary: #f8fafc;
    --lo-bg-input: #1e293b;
    --lo-border-input: #334155;
    --lo-focus-border: #10b981;
    --lo-focus-ring: rgba(16, 185, 129, 0.15);
    --lo-icon-color: #34d399;
    --lo-bg-button: #10b981;
    --lo-text-button: #fff;
    --lo-bg-hover: #059669;
    --lo-bg-stat: #1e293b;
    --lo-border-stat: rgba(255, 255, 255, 0.05);
    --lo-bar-bg: #1e293b;
    --lo-bar-fill: #10b981;
    --lo-recommendation-bg: rgba(59, 130, 246, 0.1);
    --lo-recommendation-border: rgba(59, 130, 246, 0.2);
    --lo-recommendation-icon: #60a5fa;
}

:global([data-theme='dark']) {
    --lo-bg-card: #0f172a;
    --lo-border-card: rgba(255, 255, 255, 0.05);
    --lo-text-title: #f8fafc;
    --lo-text-secondary: #94a3b8;
    --lo-text-primary: #f8fafc;
    --lo-bg-input: #1e293b;
    --lo-border-input: #334155;
    --lo-focus-border: #10b981;
    --lo-focus-ring: rgba(16, 185, 129, 0.15);
    --lo-icon-color: #34d399;
    --lo-bg-button: #10b981;
    --lo-text-button: #fff;
    --lo-bg-hover: #059669;
    --lo-bg-stat: #1e293b;
    --lo-border-stat: rgba(255, 255, 255, 0.05);
    --lo-bar-bg: #1e293b;
    --lo-bar-fill: #10b981;
    --lo-recommendation-bg: rgba(59, 130, 246, 0.1);
    --lo-recommendation-border: rgba(59, 130, 246, 0.2);
    --lo-recommendation-icon: #60a5fa;
}

.lo-container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
}

:global(.lo-games-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
}

:global(.lo-game-btn) {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    background: var(--lo-bg-card);
    border: 2px solid var(--lo-border-card);
    border-radius: 1.5rem;
    cursor: pointer;
    transition: all 0.2s;
    text-align: left;
    color: inherit;
    outline: none;
}

:global(.lo-game-btn:hover) {
    border-color: var(--lo-focus-border);
    box-shadow: var(--lo-shadow-card);
}

:global(.lo-game-icon) {
    width: 3rem;
    height: 3rem;
    border-radius: 1rem;
    background: var(--lo-bg-input);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--lo-icon-color);
}

:global(.lo-game-icon svg) {
    width: 1.5rem;
    height: 1.5rem;
}

:global(.lo-game-name) {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--lo-text-title);
    margin-bottom: 0.5rem;
}

:global(.lo-game-description) {
    font-size: 0.875rem;
    color: var(--lo-text-secondary);
    margin-bottom: 1rem;
    flex-grow: 1;
}

:global(.lo-game-footer) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid var(--lo-border-card);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--lo-text-secondary);
}

:global(.lo-arrow-icon) {
    width: 1rem;
    height: 1rem;
}

.lo-hidden {
    display: none;
}

.lo-panel {
    animation: slide-up 0.5s ease-out;
}

@keyframes slide-up {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

