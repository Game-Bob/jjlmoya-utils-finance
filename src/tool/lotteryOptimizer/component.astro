.lo-slider-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--lo-text-secondary);
}

.lo-recommendation-box {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem;
    background: var(--lo-recommendation-bg);
    border: 1px solid var(--lo-recommendation-border);
