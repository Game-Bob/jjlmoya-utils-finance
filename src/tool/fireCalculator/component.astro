---
import { Icon } from 'astro-icon/components';
import type { KnownLocale } from '../../types';

interface Props {
  locale?: KnownLocale;
  ui?: Record<string, unknown>;
}

const { ui } = Astro.props;
---

<div class="fire-container" id="fire-calculator-main" 
    data-currency-symbol={ui.currencySymbol} 
    data-currency-code={ui.currencyCode} 
    data-currency-locale={ui.currencyLocale} 
    data-time-format={ui.labelTimeRemainingFormat} 
    data-already-fi={ui.labelAlreadyFI} 
    data-unachievable={ui.labelUnachievable}
    data-label-added={ui.labelAdded}
>
    <div class="fire-grid">
        <div class="fire-panel">
            <div class="fire-input-group">
                <div class="fire-label-row">
                    <label class="fire-label">{ui.labelMonthlyExpenses}</label>
                    <span class="fire-value-display" id="val-expenses">2.500 €</span>
                </div>
                <input
                    type="range"
                    id="fire-expenses"
                    class="fire-range"
                    min="500"
                    max="10000"
                    step="50"
                    value="2500"
                />
            </div>

            <div class="fire-input-group">
                <div class="fire-label-row">
                    <label class="fire-label">
                        {ui.labelSWR}
                        <div class="fire-help">
                            <Icon name="mdi:information-outline" size={16} />
                            <span class="fire-tooltip">{ui.labelSWRTooltip}</span>
                        </div>
                    </label>
                    <span class="fire-value-display" id="val-swr">4.0 %</span>
                </div>
                <input
                    type="range"
                    id="fire-swr"
                    class="fire-range"
                    min="2.5"
                    max="6.0"
                    step="0.1"
                    value="4.0"
                />
            </div>

            <div class="fire-input-group">
                <div class="fire-label-row">
                    <label class="fire-label">{ui.labelCurrentWorth}</label>
                    <span class="fire-value-display" id="val-worth-display">50.000 €</span>
                </div>
                <input
                    type="range"
                    id="fire-worth"
                    class="fire-range"
                    min="0"
                    max="1000000"
                    step="1000"
                    value="50000"
                />
            </div>

            <div class="fire-input-group">
                <div class="fire-label-row">
                    <label class="fire-label">{ui.labelMonthlySavings}</label>
                    <span class="fire-value-display" id="val-savings">1.000 €</span>
                </div>
                <input
                    type="range"
                    id="fire-savings"
                    class="fire-range"
                    min="0"
                    max="5000"
                    step="50"
                    value="1000"
                />
            </div>

            <div class="fire-input-group">
                <div class="fire-label-row">
                    <label class="fire-label">
                        {ui.labelAnnualReturn}
                        <div class="fire-help">
                            <Icon name="mdi:information-outline" size={16} />
                            <span class="fire-tooltip">{ui.labelReturnTooltip}</span>
                        </div>
                    </label>
                    <span class="fire-value-display" id="val-return">7.0 %</span>
                </div>
                <input
                    type="range"
                    id="fire-return"
                    class="fire-range"
                    min="1"
                    max="12"
                    step="0.5"
                    value="7"
                />
            </div>

            <div class="fire-checklist">
                <h3>{ui.labelFreedomMilestones}</h3>
                <div class="fire-milestones">
                    <div class="milestone-item lean">
                        <div class="milestone-header">
                            <span>{ui.labelLeanFIRE}</span>
                            <span id="label-lean">0%</span>
                        </div>
                        <div class="milestone-bar-bg">
                            <div class="milestone-bar-fill" id="bar-lean" style="width: 0%"></div>
                        </div>
                    </div>
                    <div class="milestone-item barista">
                        <div class="milestone-header">
                            <span>{ui.labelBaristaFIRE}</span>
                            <span id="label-barista">0%</span>
                        </div>
                        <div class="milestone-bar-bg">
                            <div class="milestone-bar-fill" id="bar-barista" style="width: 0%"></div>
                        </div>
                    </div>
                    <div class="milestone-item fat">
                        <div class="milestone-header">
                            <span>{ui.labelFatFIRE}</span>
                            <span id="label-fat">0%</span>
                        </div>
                        <div class="milestone-bar-bg">
                            <div class="milestone-bar-fill" id="bar-fat" style="width: 0%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="fire-result-panel">
            <div class="fire-main-result">
                <span class="fire-magic-number-label">{ui.labelMagicNumber}</span>
                <div class="fire-magic-number" id="fire-number">750.000 €</div>
                <div class="fire-countdown" id="fire-time">{ui.labelTimeRemaining}</div>
            </div>

            <div class="fire-chart-container" id="fire-chart">
                <svg class="fire-line-svg" preserveAspectRatio="none" id="svg-chart">
                    <path class="fire-path-savings" id="chart-area" d="" />
                    <path class="fire-path" id="chart-line" d="" />
                </svg>
            </div>

            <div class="fire-checklist">
                <h3>{ui.labelHiddenCostsChecklist}</h3>
                <div class="checklist-grid" id="fire-checklist-grid">
                    <label class="checklist-item"><input type="checkbox" data-cost="200" /> {ui.labelHealth}</label>
                    <label class="checklist-item"><input type="checkbox" data-cost="150" /> {ui.labelTaxes}</label>
                    <label class="checklist-item"><input type="checkbox" data-cost="100" /> {ui.labelHome}</label>
                    <label class="checklist-item"><input type="checkbox" data-cost="300" /> {ui.labelTravel}</label>
                    <label class="checklist-item"><input type="checkbox" data-cost="100" /> {ui.labelEmergency}</label>
                    <label class="checklist-item"><input type="checkbox" data-cost="50" /> {ui.labelSubscriptions}</label>
                </div>
                <div id="checklist-feedback" class="checklist-feedback"></div>
            </div>

            <div class="fire-actions">
                <button class="fire-btn fire-btn-primary" id="btn-export">
                    <Icon name="mdi:file-pdf-box" size={20} />
                    {ui.labelSavePlan}
                </button>
            </div>
        </div>
    </div>
</div>


<script>
    import { FIRELogic } from './logic';

    const expensesIn = document.getElementById('fire-expenses') as HTMLInputElement | null;
    const swrIn = document.getElementById('fire-swr') as HTMLInputElement | null;
    const worthIn = document.getElementById('fire-worth') as HTMLInputElement | null;
    const savingsIn = document.getElementById('fire-savings') as HTMLInputElement | null;
    const returnIn = document.getElementById('fire-return') as HTMLInputElement | null;

    const valExpenses = document.getElementById('val-expenses');
    const valSwr = document.getElementById('val-swr');
    const valWorth = document.getElementById('val-worth-display');
    const valSavings = document.getElementById('val-savings');
    const valReturn = document.getElementById('val-return');

    const fireNumber = document.getElementById('fire-number');
    const fireTime = document.getElementById('fire-time');

    const barLean = document.getElementById('bar-lean');
    const barBarista = document.getElementById('bar-barista');
    const barFat = document.getElementById('bar-fat');
    const labelLean = document.getElementById('label-lean');
    const labelBarista = document.getElementById('label-barista');
    const labelFat = document.getElementById('label-fat');

    const checklistGrid = document.getElementById('fire-checklist-grid');
    const checklistFeedback = document.getElementById('checklist-feedback');

    const chartLine = document.getElementById('chart-line') as SVGPathElement | null;
    const chartArea = document.getElementById('chart-area') as SVGPathElement | null;

    const container = document.querySelector('.fire-container') as HTMLElement;
    const currencyLocale = container?.getAttribute('data-currency-locale') || 'es-ES';
    const timeFormatTemplate = container?.getAttribute('data-time-format') || 'You have {years} years and {months} months left';
    const labelAlreadyFI = container?.getAttribute('data-already-fi') || 'You have already achieved financial freedom!';
    const labelUnachievable = container?.getAttribute('data-unachievable') || 'Goal unachievable with this savings rate';
    const labelAdded = container?.getAttribute('data-label-added') || 'Added:';

    function formatCurrency(val: number): string {
      return new Intl.NumberFormat(currencyLocale, {
        style: 'currency',
        currency: container?.getAttribute('data-currency-code') || 'EUR',
        maximumFractionDigits: 0,
      }).format(val);
    }

    function updateDisplay(result: ReturnType<typeof FIRELogic.calculateFIRE>, extraCosts: number) {
      if (fireNumber) fireNumber.textContent = formatCurrency(result.magicNumber);
      if (valExpenses) {
        valExpenses.textContent = formatCurrency(result.monthlyExpenses);
        valExpenses.style.color = extraCosts > 0 ? 'var(--fire-accent)' : 'var(--fire-primary)';
      }
      if (valSwr) valSwr.textContent = result.swr.toFixed(1) + ' %';
      if (valWorth) valWorth.textContent = formatCurrency(result.currentWorth);
      if (valSavings) valSavings.textContent = formatCurrency(result.monthlySavings);
      if (valReturn) valReturn.textContent = result.annualReturn.toFixed(1) + ' %';
    }

    function updateMilestones(result: ReturnType<typeof FIRELogic.calculateFIRE>) {
      const update = (current: number, target: number, bar: HTMLElement | null, label: HTMLElement | null) => {
        const pct = Math.min(100, (current / target) * 100);
        if (bar) bar.style.width = pct + '%';
        if (label) label.textContent = pct.toFixed(0) + '%';
      };
      update(result.currentWorth, result.leanTarget, barLean, labelLean);
      update(result.currentWorth, result.baristaTarget, barBarista, labelBarista);
      update(result.currentWorth, result.fatTarget, barFat, labelFat);
    }

    function updateChart(result: ReturnType<typeof FIRELogic.calculateFIRE>) {
      if (!chartLine || !chartArea) return;
      const { wealthHistory } = result;
      const pointsCount = wealthHistory.length;
      const maxVal = Math.max(result.magicNumber * 1.1, ...wealthHistory);
      let d = '';
      wealthHistory.forEach((v, i) => {
        const x = (i / (pointsCount - 1)) * 100;
        const y = 100 - (v / maxVal) * 100;
        d += (i === 0 ? 'M ' : ' L ') + x + ' ' + y;
      });
      chartLine.setAttribute('d', d);
      chartArea.setAttribute('d', d + ' L 100 100 L 0 100 Z');
      document.getElementById('svg-chart')?.setAttribute('viewBox', '0 0 100 100');
    }

    function updateTime(result: ReturnType<typeof FIRELogic.calculateFIRE>) {
      if (!fireTime) return;
      if (result.isAlreadyFI) {
        fireTime.textContent = labelAlreadyFI;
      } else if (!result.isAchievable) {
        fireTime.textContent = labelUnachievable;
      } else {
        const formatted = timeFormatTemplate
          .split('{years}').join(String(result.yearsToFI))
          .split('{months}').join(String(result.monthsToFI));
        fireTime.textContent = formatted;
      }
    }

    function calculateFIRE() {
        if (!expensesIn || !swrIn || !worthIn || !savingsIn || !returnIn) return;

        let extraCosts = 0;
        const checks = checklistGrid?.querySelectorAll('input[type="checkbox"]:checked') as NodeListOf<HTMLInputElement>;
        checks.forEach((check) => {
            extraCosts += parseFloat(check.getAttribute('data-cost') || '0');
        });

        const result = FIRELogic.calculateFIRE({
          monthlyExpenses: parseFloat(expensesIn.value),
          swr: parseFloat(swrIn.value),
          currentWorth: parseFloat(worthIn.value),
          monthlySavings: parseFloat(savingsIn.value),
          annualReturn: parseFloat(returnIn.value),
          extraCosts,
        });

        updateDisplay(result, extraCosts);
        updateMilestones(result);
        updateTime(result);
        updateChart(result);
    }

    [expensesIn, swrIn, worthIn, savingsIn, returnIn].forEach((el) => {
        el?.addEventListener('input', calculateFIRE);
    });

    checklistGrid?.addEventListener('change', (e) => {
        const target = e.target as HTMLInputElement;
        if (target && checklistFeedback) {
            if (target.checked) {
                checklistFeedback.textContent = `${labelAdded} ${target.parentElement?.textContent?.trim()}`;
                checklistFeedback.classList.add('visible');
                setTimeout(() => checklistFeedback.classList.remove('visible'), 2000);
            }
        }
        calculateFIRE();
    });

    async function exportPDF() {
      const { default: jsPDF } = await import('jspdf');
      const { default: html2canvas } = await import('html2canvas');
      const element = document.getElementById('fire-calculator-main');
      if (!element) return;
      const canvas = await html2canvas(element, {
        scale: 2,
        useCORS: true,
        backgroundColor: '#ffffff',
        onclone: (clonedDoc) => {
          const clonedEl = clonedDoc.getElementById('fire-calculator-main');
          if (!clonedEl) return;
          clonedEl.style.padding = '40px';
          clonedEl.style.background = '#ffffff';
          clonedEl.style.color = '#000000';
          clonedEl.style.width = '1000px';
          const results = clonedEl.querySelector('.fire-result-panel') as HTMLElement;
          if (results) {
            results.style.background = '#f9fafb';
            results.style.color = '#000000';
          }
          const magic = clonedEl.querySelector('.fire-magic-number') as HTMLElement;
          if (magic) magic.style.color = '#10b981';
        },
      });
      const imgData = canvas.toDataURL('image/png');
      const pdf = new jsPDF('p', 'pt', 'a4');
      pdf.addImage(imgData, 'PNG', 0, 0, 595.28, (canvas.height * 595.28) / canvas.width);
      pdf.save('fire-plan.pdf');
    }

    const btnExport = document.getElementById('btn-export');
    btnExport?.addEventListener('click', () => {
      exportPDF().catch((error) => console.error('PDF error:', error));
    });

    calculateFIRE();
</script>
