---
import { SEORenderer } from '@jjlmoya/utils-shared';
import type { ProfitabilityLocaleContent } from './entry';

interface Props {
  content: ProfitabilityLocaleContent;
  locale: string;
}

const { content, locale } = Astro.props;
---

{content.seo && content.seo.length > 0 && <SEORenderer content={{ locale, sections: content.seo }} />}
